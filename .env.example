# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Nightscout base URL, e.g. https://algerw.mooo.com  (no trailing slash)
NIGHTSCOUT_URL=

# Nightscout access token or API secret.
# Preferred: a read-capable access token (Admin Tools -> Subjects/roles -> token).
# The token is passed as ?token=... on REST v1 requests.
NIGHTSCOUT_TOKEN=

# Optional: legacy API-SECRET (sha1-hashed and sent as api-secret header).
# Only used if NIGHTSCOUT_TOKEN is empty. Prefer a token.
NIGHTSCOUT_API_SECRET=

# Local timezone for circadian features and time-of-day binning (IANA name).
# Example: America/New_York
LOCAL_TIMEZONE=America/New_York

# Where to cache pulled data and write run artifacts (gitignored).
LOOPTUNER_DATA_DIR=./data
LOOPTUNER_RUNS_DIR=./runs

# Optional: Anthropic API key, ONLY used by the optional backtest narrator (--narrate).
# The LLM is a narrator at the end of the pipeline, never the predictor.
ANTHROPIC_API_KEY=
